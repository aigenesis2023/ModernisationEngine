{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-base.schema.json",
  "title": "Knowledge Base",
  "description": "Raw knowledge gathered from research — layout-agnostic. The research agent gathers facts, insights, and teachable moments. The generation agent decides how to present them.",

  "type": "object",
  "required": ["topic", "learningObjectives", "contentAreas"],
  "additionalProperties": false,

  "properties": {
    "topic": {
      "type": "object",
      "required": ["title", "brief"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Short course title derived from the topic brief"
        },
        "brief": {
          "type": "string",
          "description": "The original topic brief from the user"
        },
        "targetAudience": {
          "type": "string",
          "description": "Inferred or stated target audience"
        },
        "difficultyLevel": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced"],
          "description": "Overall course difficulty"
        },
        "estimatedDuration": {
          "type": "string",
          "description": "Estimated learning time (e.g. '30 minutes', '1 hour')"
        }
      }
    },

    "learningObjectives": {
      "type": "array",
      "description": "3-8 specific, measurable learning objectives derived from research",
      "items": { "type": "string" },
      "minItems": 2
    },

    "contentAreas": {
      "type": "array",
      "description": "Major topic areas discovered through research. Raw knowledge — no layout or component decisions.",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["title", "keyPoints"],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "description": "Content area heading"
          },
          "summary": {
            "type": "string",
            "description": "2-3 sentence overview of this area"
          },
          "keyPoints": {
            "type": "array",
            "description": "All facts, statistics, definitions, claims, and concepts as uniform knowledge points. Every type of knowledge goes here — the generation agent decides how to present each one.",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["point"],
              "additionalProperties": false,
              "properties": {
                "point": {
                  "type": "string",
                  "description": "A factual claim, statistic, definition, concept, or insight"
                },
                "detail": {
                  "type": "string",
                  "description": "Supporting explanation, context, or evidence"
                },
                "citation": {
                  "type": "string",
                  "description": "Source URL or reference for this claim"
                }
              }
            }
          },
          "teachableMoments": {
            "type": "array",
            "description": "Surprising insights, case studies, analogies, contrasts, and decision frameworks that make knowledge stick. These are pedagogical hooks — not just facts.",
            "items": {
              "type": "object",
              "required": ["type", "hook"],
              "additionalProperties": false,
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["surprising-insight", "case-study", "analogy", "contrast", "decision-framework"],
                  "description": "What kind of teachable moment this is"
                },
                "hook": {
                  "type": "string",
                  "description": "One-line attention grabber — the 'wait, really?' moment"
                },
                "detail": {
                  "type": "string",
                  "description": "Full explanation of the insight, story, or framework"
                },
                "citation": {
                  "type": "string",
                  "description": "Source URL or reference"
                }
              }
            }
          }
        }
      }
    },

    "sources": {
      "type": "array",
      "description": "All sources used in research, for attribution and verification",
      "items": {
        "type": "object",
        "required": ["title", "type"],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "description": "Source URL"
          },
          "title": {
            "type": "string",
            "description": "Source title or description"
          },
          "type": {
            "type": "string",
            "enum": ["web-research", "user-url", "uploaded-document"],
            "description": "How this source was obtained"
          }
        }
      }
    },

    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "researchModel": {
          "type": "string",
          "description": "Which model/agent performed the research"
        },
        "inputTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["topic-brief", "urls", "uploaded-document"]
          },
          "description": "What input types were used"
        }
      }
    }
  }
}
